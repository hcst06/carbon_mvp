.container {
  min-height: 100vh;
  padding: 30rpx;
  background:
    radial-gradient(circle at top right, rgba(245, 158, 11, 0.14), transparent 20%),
    linear-gradient(180deg, #f7fbf6 0%, #f1f8f2 50%, #f9fbf8 100%);
}

.header {
  margin-bottom: 30rpx;
  padding: 18rpx 6rpx;
}

.title {
  display: block;
  font-size: 42rpx;
  font-weight: 700;
  color: #14532d;
  margin-bottom: 10rpx;
}

.subtitle {
  display: block;
  font-size: 26rpx;
  color: #6b7280;
  line-height: 1.5;
}

.products-list {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.product-card {
  width: calc(50% - 10rpx);
  background-color: rgba(255, 255, 255, 0.96);
  border-radius: 22rpx;
  overflow: hidden;
  box-shadow: 0 16rpx 30rpx rgba(15, 23, 42, 0.06);
}

.product-card:active {
  transform: translateY(-4rpx);
}

.product-image {
  width: 100%;
  height: 300rpx;
  background:
    linear-gradient(135deg, #fff7ed, #fef3c7);
  display: flex;
  align-items: center;
  justify-content: center;
}

.product-image image {
  width: 140rpx;
  height: 140rpx;
}

.product-info {
  padding: 22rpx;
}

.product-name {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #14532d;
  margin-bottom: 10rpx;
}

.product-desc {
  display: block;
  font-size: 24rpx;
  color: #6b7280;
  line-height: 1.5;
  margin-bottom: 15rpx;
  height: 72rpx;
  overflow: hidden;
}

.product-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.product-price {
  font-size: 28rpx;
  font-weight: 700;
  color: #d97706;
}

.product-stock {
  font-size: 22rpx;
  color: #9ca3af;
}

.empty {
  text-align: center;
  padding: 110rpx 0;
}

.empty-icon {
  width: 170rpx;
  height: 170rpx;
  margin: 0 auto 26rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #fef3c7, #fde68a);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 700;
  color: #92400e;
  letter-spacing: 2rpx;
}

.empty-text {
  display: block;
  font-size: 28rpx;
  color: #9ca3af;
}

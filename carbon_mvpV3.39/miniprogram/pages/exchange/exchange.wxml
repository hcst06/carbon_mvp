<view class="container">
  <view class="header">
    <text class="title">积分兑换</text>
    <text class="subtitle">把绿色出行积累下来的积分，兑换成助农好物。</text>
  </view>

  <view class="products-list">
    <view
      class="product-card"
      wx:for="{{products}}"
      wx:key="id"
      bindtap="exchangeProduct"
      data-id="{{item.id}}"
    >
      <view class="product-image">
        <image src="{{item.image_url || '/images/product.png'}}" mode="aspectFit"></image>
      </view>
      <view class="product-info">
        <text class="product-name">{{item.name}}</text>
        <text class="product-desc">{{item.description}}</text>
        <view class="product-footer">
          <text class="product-price">{{item.price_points}} 积分</text>
          <text class="product-stock">库存 {{item.stock}}</text>
        </view>
      </view>
    </view>
  </view>

  <view class="empty" wx:if="{{products.length === 0}}">
    <view class="empty-icon">SHOP</view>
    <text class="empty-text">暂时还没有可兑换商品</text>
  </view>
</view>

.container {
  min-height: 100vh;
  background:
    radial-gradient(circle at top right, rgba(34, 197, 94, 0.16), transparent 24%),
    radial-gradient(circle at top left, rgba(250, 204, 21, 0.12), transparent 18%),
    linear-gradient(180deg, #f4fbf5 0%, #eef8f1 46%, #f8fbf7 100%);
  padding: 34rpx 28rpx 44rpx;
}

.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 40rpx;
  animation: fadeIn 0.5s ease-in;
}

.user-info {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(74, 222, 128, 0.45);
  box-shadow: 0 12rpx 28rpx rgba(74, 222, 128, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #14532d;
  background: linear-gradient(135deg, #ffffff, #ecfdf5);
  overflow: hidden;
}

.avatar-image {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.avatar-mark {
  font-size: 34rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
}

.user-details {
  flex: 1;
}

.username {
  font-size: 32rpx;
  font-weight: bold;
  color: #374151;
  margin-bottom: 5rpx;
  display: block;
}

.points {
  font-size: 24rpx;
  color: #16a34a;
  font-weight: bold;
}

.login-btn {
  font-size: 24rpx;
  color: #2563eb;
  font-weight: bold;
}

.hero-section {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #166534 0%, #22c55e 54%, #86efac 100%);
  border-radius: 34rpx;
  padding: 40rpx;
  margin-bottom: 40rpx;
  box-shadow: 0 20rpx 40rpx rgba(21, 128, 61, 0.18);
  animation: slideInUp 0.6s ease-out;
  position: relative;
  overflow: hidden;
}

.hero-section::after {
  content: '';
  position: absolute;
  right: -80rpx;
  top: -60rpx;
  width: 260rpx;
  height: 260rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.08);
}

.hero-content {
  flex: 1;
  margin-right: 30rpx;
  position: relative;
  z-index: 1;
}

.hero-title {
  font-size: 48rpx;
  font-weight: bold;
  color: white;
  margin-bottom: 10rpx;
  display: block;
}

.hero-title.highlight {
  color: #fef3c7;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.2);
}

.hero-subtitle {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
  line-height: 1.6;
}

.hero-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 24rpx;
}

.hero-tag {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.16);
  color: #f0fdf4;
  font-size: 20rpx;
  font-weight: 600;
  letter-spacing: 1rpx;
}

.hero-image {
  width: 200rpx;
  height: 200rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  animation: bounce 2s infinite;
  z-index: 1;
}

.hero-orbit {
  position: absolute;
  border-radius: 50%;
  border: 2rpx solid rgba(255, 255, 255, 0.22);
}

.orbit-one {
  width: 170rpx;
  height: 170rpx;
}

.orbit-two {
  width: 120rpx;
  height: 120rpx;
}

.hero-core {
  width: 86rpx;
  height: 86rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #fef3c7, #fde68a);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.16);
}

.hero-core-text {
  font-size: 38rpx;
  font-weight: 700;
  color: #14532d;
}

.stats-section {
  display: flex;
  justify-content: space-between;
  margin-bottom: 40rpx;
  animation: fadeIn 0.8s ease-in;
}

.step-card {
  margin-bottom: 40rpx;
  padding: 28rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 16rpx 32rpx rgba(15, 23, 42, 0.06);
}

.step-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.step-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #14532d;
  margin-bottom: 8rpx;
}

.step-subtitle {
  display: block;
  font-size: 22rpx;
  color: #6b7280;
  line-height: 1.5;
}

.step-sync-btn {
  min-width: 140rpx;
  height: 70rpx;
  line-height: 70rpx;
  margin: 0;
  padding: 0 24rpx;
  border-radius: 999rpx;
  border: none;
  background: linear-gradient(135deg, #16a34a, #22c55e);
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 700;
}

.step-body {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  gap: 20rpx;
}

.step-main {
  display: flex;
  align-items: baseline;
}

.step-value {
  font-size: 58rpx;
  font-weight: 700;
  color: #16a34a;
}

.step-unit {
  margin-left: 10rpx;
  font-size: 24rpx;
  color: #6b7280;
}

.step-time {
  font-size: 22rpx;
  color: #9ca3af;
}

.stat-card {
  flex: 1;
  background-color: rgba(255, 255, 255, 0.94);
  border-radius: 24rpx;
  padding: 30rpx 20rpx;
  text-align: center;
  margin: 0 10rpx;
  box-shadow: 0 16rpx 32rpx rgba(15, 23, 42, 0.06);
}

.stat-icon {
  width: 84rpx;
  height: 84rpx;
  margin: 0 auto 20rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  font-weight: 700;
  color: #ffffff;
  letter-spacing: 1rpx;
}

.stat-green {
  background: linear-gradient(135deg, #16a34a, #4ade80);
}

.stat-gold {
  background: linear-gradient(135deg, #d97706, #fbbf24);
}

.stat-blue {
  background: linear-gradient(135deg, #2563eb, #60a5fa);
}

.stat-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #16a34a;
  margin-bottom: 10rpx;
  display: block;
}

.stat-label {
  font-size: 20rpx;
  color: #6b7280;
}

.features-section {
  margin-bottom: 40rpx;
  animation: fadeIn 1s ease-in;
}

.section-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #374151;
  margin-bottom: 30rpx;
  text-align: center;
  position: relative;
}

.section-title::after {
  content: '';
  position: absolute;
  bottom: -10rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 100rpx;
  height: 6rpx;
  background: linear-gradient(90deg, #4ade80, #16a34a);
  border-radius: 3rpx;
}

.feature-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}

.feature-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 28rpx 24rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.94);
  margin: 8rpx;
  text-align: center;
  box-shadow: 0 16rpx 30rpx rgba(15, 23, 42, 0.05);
}

.feature-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  margin-top: 10rpx;
  width: 100%;
}

.feature-icon {
  width: 100rpx;
  height: 100rpx;
  margin: 0 auto 20rpx;
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 14rpx 24rpx rgba(15, 23, 42, 0.12);
}

.feature-icon.calculate {
  background: linear-gradient(135deg, #3b82f6, #60a5fa);
}

.feature-icon.track {
  background: linear-gradient(135deg, #8b5cf6, #a78bfa);
}

.feature-icon.exchange {
  background: linear-gradient(135deg, #f59e0b, #fbbf24);
}

.feature-icon.stats {
  background: linear-gradient(135deg, #ef4444, #f87171);
}

.feature-badge {
  font-size: 22rpx;
  font-weight: 700;
  color: #ffffff;
  letter-spacing: 1.5rpx;
}

.feature-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #374151;
  margin-bottom: 16rpx;
}

.feature-desc {
  font-size: 20rpx;
  color: #6b7280;
  line-height: 1.5;
}

.news-section {
  margin-bottom: 40rpx;
  animation: fadeIn 1.2s ease-in;
}

.news-card {
  display: flex;
  background-color: rgba(255, 255, 255, 0.96);
  border-radius: 24rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 14rpx 28rpx rgba(15, 23, 42, 0.05);
}

.news-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 24rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  font-weight: 700;
  color: #ffffff;
  letter-spacing: 1rpx;
  box-shadow: 0 10rpx 22rpx rgba(0, 0, 0, 0.08);
}

.news-guide {
  background: linear-gradient(135deg, #0f766e, #2dd4bf);
}

.news-rural {
  background: linear-gradient(135deg, #92400e, #f59e0b);
}

.news-content {
  flex: 1;
}

.news-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #374151;
  margin-bottom: 10rpx;
  display: block;
  line-height: 1.4;
}

.news-desc {
  font-size: 20rpx;
  color: #6b7280;
  margin-bottom: 10rpx;
  line-height: 1.5;
}

.news-date {
  font-size: 18rpx;
  color: #9ca3af;
}

.footer {
  text-align: center;
  padding: 40rpx 0;
  animation: fadeIn 1.4s ease-in;
}

.footer-text {
  font-size: 24rpx;
  color: #6b7280;
  margin-bottom: 10rpx;
  display: block;
}

.footer-subtext {
  font-size: 20rpx;
  color: #9ca3af;
}

@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes slideInUp {
  from {
    opacity: 0;
    transform: translateY(40rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes bounce {
  0%, 20%, 50%, 80%, 100% {
    transform: translateY(0);
  }
  40% {
    transform: translateY(-20rpx);
  }
  60% {
    transform: translateY(-10rpx);
  }
}

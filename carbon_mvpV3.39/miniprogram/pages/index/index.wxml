<view class="container">
  <view class="header">
    <view class="user-info" wx:if="{{userInfo}}">
      <view class="avatar">
        <image wx:if="{{userInfo.avatar_url}}" class="avatar-image" src="{{userInfo.avatar_url}}" mode="aspectFill"></image>
        <text wx:else class="avatar-mark">{{userInfo.username ? userInfo.username.substring(0, 1) : 'C'}}</text>
      </view>
      <view class="user-details">
        <text class="username">{{userInfo.nickname || userInfo.username}}</text>
        <text class="points">总积分 {{userInfo.total_points || 0}}</text>
      </view>
    </view>
    <view class="user-info" wx:else>
      <view class="avatar">
        <text class="avatar-mark">C</text>
      </view>
      <view class="user-details">
        <text class="username">未登录</text>
        <text class="login-btn" bindtap="goToLogin">点击登录</text>
      </view>
    </view>
  </view>

  <view class="hero-section">
    <view class="hero-content">
      <text class="hero-title">绿色出行</text>
      <text class="hero-title highlight">助力乡村振兴</text>
      <text class="hero-subtitle">把每一次低碳出行变成积分回馈，让环保行动和助农价值真正连接起来。</text>
      <view class="hero-tags">
        <text class="hero-tag">CO2</text>
        <text class="hero-tag">POINTS</text>
        <text class="hero-tag">RURAL</text>
      </view>
    </view>
    <view class="hero-image">
      <view class="hero-orbit orbit-one"></view>
      <view class="hero-orbit orbit-two"></view>
      <view class="hero-core">
        <text class="hero-core-text">C</text>
      </view>
    </view>
  </view>

  <view class="stats-section">
    <view class="stat-card">
      <view class="stat-icon stat-green">CO2</view>
      <text class="stat-value">{{stats.total_reduction || 0}}</text>
      <text class="stat-label">总减排量(g)</text>
    </view>
    <view class="stat-card">
      <view class="stat-icon stat-gold">PTS</view>
      <text class="stat-value">{{userInfo ? (userInfo.total_points || 0) : 0}}</text>
      <text class="stat-label">总积分</text>
    </view>
    <view class="stat-card">
      <view class="stat-icon stat-blue">TRIP</view>
      <text class="stat-value">{{stats.total_trips || 0}}</text>
      <text class="stat-label">出行次数</text>
    </view>
  </view>

  <view class="step-card" wx:if="{{userInfo}}">
    <view class="step-header">
      <view>
        <text class="step-title">微信运动步数</text>
        <text class="step-subtitle">同步最新步数，丰富你的绿色生活画像</text>
      </view>
      <button class="step-sync-btn" bindtap="syncWeRunData" loading="{{syncLoading}}">同步</button>
    </view>
    <view class="step-body">
      <view class="step-main">
        <text class="step-value">{{stats.step_count || userInfo.step_count || 0}}</text>
        <text class="step-unit">步</text>
      </view>
      <text class="step-time">最近同步：{{stats.step_updated_at || '未同步'}}</text>
    </view>
  </view>

  <view class="features-section">
    <text class="section-title">核心功能</text>
    <view class="feature-grid">
      <view class="feature-card" bindtap="goToCalculate">
        <view class="feature-icon calculate">
          <text class="feature-badge">CALC</text>
        </view>
        <view class="feature-content">
          <text class="feature-title">碳积分计算</text>
          <text class="feature-desc">记录出行并计算减排与积分</text>
        </view>
      </view>
      <view class="feature-card" bindtap="goToTrack">
        <view class="feature-icon track">
          <text class="feature-badge">GO</text>
        </view>
        <view class="feature-content">
          <text class="feature-title">出行轨迹</text>
          <text class="feature-desc">实时记录绿色出行轨迹</text>
        </view>
      </view>
      <view class="feature-card" bindtap="goToExchange">
        <view class="feature-icon exchange">
          <text class="feature-badge">SHOP</text>
        </view>
        <view class="feature-content">
          <text class="feature-title">积分兑换</text>
          <text class="feature-desc">用积分兑换助农产品</text>
        </view>
      </view>
      <view class="feature-card" bindtap="goToStats">
        <view class="feature-icon stats">
          <text class="feature-badge">DATA</text>
        </view>
        <view class="feature-content">
          <text class="feature-title">数据统计</text>
          <text class="feature-desc">查看减排趋势与出行表现</text>
        </view>
      </view>
    </view>
  </view>
</view>

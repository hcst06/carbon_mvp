.container {
  min-height: 100vh;
  background:
    radial-gradient(circle at top right, rgba(250, 204, 21, 0.18), transparent 28%),
    linear-gradient(180deg, #f6fff7 0%, #eefaf2 46%, #f8fbf7 100%);
  padding: 36rpx 28rpx 48rpx;
}

.header {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  margin-bottom: 28rpx;
  padding: 26rpx 10rpx 12rpx;
}

.title {
  font-size: 44rpx;
  font-weight: 700;
  color: #14532d;
  margin-bottom: 10rpx;
}

.subtitle {
  font-size: 24rpx;
  color: #5f6f65;
  line-height: 1.6;
}

.tabs {
  display: flex;
  padding: 10rpx;
  background: rgba(255, 255, 255, 0.92);
  border-radius: 28rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 18rpx 36rpx rgba(21, 128, 61, 0.08);
}

.tab {
  flex: 1;
  text-align: center;
  padding: 18rpx 12rpx;
  font-size: 28rpx;
  color: #6b7280;
  border-radius: 22rpx;
}

.tab.active {
  color: #14532d;
  font-weight: 700;
  background: linear-gradient(135deg, #dcfce7, #fef9c3);
  box-shadow: inset 0 0 0 2rpx rgba(34, 197, 94, 0.14);
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1f2937;
  margin-bottom: 20rpx;
  margin-top: 34rpx;
  padding-left: 14rpx;
  border-left: 8rpx solid #22c55e;
}

.achievement-list,
.task-list {
  margin-bottom: 40rpx;
}

.achievement-card,
.task-card {
  display: flex;
  background: rgba(255, 255, 255, 0.96);
  border-radius: 28rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 18rpx 40rpx rgba(15, 23, 42, 0.06);
  align-items: center;
}

.achievement-card.achieved {
  border: 2rpx solid rgba(34, 197, 94, 0.18);
}

.achievement-card.unachieved {
  border: 2rpx solid rgba(148, 163, 184, 0.18);
  opacity: 0.82;
}

.achievement-icon,
.task-icon {
  width: 96rpx;
  height: 96rpx;
  margin-right: 28rpx;
  border-radius: 26rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.achievement-icon {
  background: linear-gradient(135deg, #14532d, #22c55e);
  box-shadow: 0 12rpx 24rpx rgba(21, 128, 61, 0.18);
}

.task-icon {
  background: linear-gradient(135deg, #2563eb, #38bdf8);
  box-shadow: 0 12rpx 24rpx rgba(37, 99, 235, 0.18);
}

.icon-text {
  font-size: 22rpx;
  color: #ffffff;
  font-weight: 700;
  letter-spacing: 2rpx;
}

.achievement-info,
.task-info {
  flex: 1;
}

.achievement-name,
.task-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #1f2937;
  margin-bottom: 8rpx;
}

.achievement-desc,
.task-desc {
  font-size: 24rpx;
  color: #6b7280;
  margin-bottom: 10rpx;
  line-height: 1.5;
}

.achievement-reward,
.task-reward {
  font-size: 24rpx;
  color: #15803d;
  font-weight: 700;
}

.achievement-status,
.task-status {
  padding: 12rpx 20rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 700;
}

.achievement-status.achieved,
.task-status {
  background-color: #dcfce7;
  color: #15803d;
}

.achievement-status.unachieved {
  background-color: #f3f4f6;
  color: #6b7280;
}

.task-card.active {
  border: 2rpx solid rgba(59, 130, 246, 0.14);
}

.task-card.completed {
  border: 2rpx solid rgba(34, 197, 94, 0.16);
  opacity: 0.82;
}

.task-progress {
  margin: 14rpx 0;
}

.progress-bar {
  width: 100%;
  height: 12rpx;
  background-color: #e5e7eb;
  border-radius: 999rpx;
  margin-bottom: 8rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #3b82f6, #10b981);
  border-radius: 999rpx;
}

.progress-text {
  font-size: 20rpx;
  color: #6b7280;
}

.task-button {
  height: 74rpx;
  line-height: 74rpx;
  padding: 0 28rpx;
  background: linear-gradient(135deg, #2563eb 0%, #10b981 100%);
  color: #ffffff;
  border: none;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 700;
  min-width: 170rpx;
  margin: 0;
}

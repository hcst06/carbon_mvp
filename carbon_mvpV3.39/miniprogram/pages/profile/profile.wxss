.container {
  min-height: 100vh;
  padding: 30rpx;
  background:
    radial-gradient(circle at top right, rgba(34, 197, 94, 0.14), transparent 20%),
    linear-gradient(180deg, #f5fbf6 0%, #eff8f2 50%, #f8fbf8 100%);
}

.user-card {
  background: linear-gradient(135deg, #166534 0%, #22c55e 54%, #86efac 100%);
  border-radius: 28rpx;
  padding: 40rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 20rpx 40rpx rgba(21, 128, 61, 0.16);
}

.user-info {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  background: linear-gradient(135deg, #ffffff, #ecfdf5);
  margin-right: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 12rpx 28rpx rgba(0, 0, 0, 0.12);
  overflow: hidden;
}

.avatar-image {
  width: 100%;
  height: 100%;
  border-radius: 60rpx;
}

.avatar-mark {
  font-size: 48rpx;
  font-weight: 700;
  color: #14532d;
  letter-spacing: 2rpx;
}

.user-details {
  flex: 1;
}

.username {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: white;
  margin-bottom: 10rpx;
}

.email {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
}

.user-stats {
  display: flex;
  justify-content: space-between;
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.3);
}

.stat-item {
  text-align: center;
  flex: 1;
}

.stat-label {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-bottom: 10rpx;
}

.stat-value {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: white;
}

.text-primary {
  color: white;
}

.sync-card {
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.3);
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 20rpx;
}

.sync-copy {
  flex: 1;
}

.sync-title {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #ffffff;
  margin-bottom: 8rpx;
}

.sync-desc {
  display: block;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.86);
}

.sync-btn {
  min-width: 160rpx;
  height: 72rpx;
  line-height: 72rpx;
  margin: 0;
  padding: 0 22rpx;
  border: none;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #fef3c7, #fde68a);
  color: #14532d;
  font-size: 24rpx;
  font-weight: 700;
}

.menu-list {
  background-color: rgba(255, 255, 255, 0.96);
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 18rpx 36rpx rgba(15, 23, 42, 0.06);
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f3f4f6;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  width: 86rpx;
  height: 86rpx;
  margin-right: 20rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  font-weight: 700;
  color: #ffffff;
  letter-spacing: 1rpx;
}

.menu-records {
  background: linear-gradient(135deg, #2563eb, #60a5fa);
}

.menu-stats {
  background: linear-gradient(135deg, #0f766e, #2dd4bf);
}

.menu-key {
  background: linear-gradient(135deg, #d97706, #fbbf24);
}

.menu-exit {
  background: linear-gradient(135deg, #dc2626, #fb7185);
}

.menu-text {
  flex: 1;
  font-size: 28rpx;
  color: #374151;
}

.arrow-icon {
  width: 30rpx;
  height: 30rpx;
  color: #9ca3af;
  font-size: 30rpx;
  line-height: 30rpx;
  text-align: center;
}

.text-danger {
  color: #ef4444;
}

.login-prompt {
  text-align: center;
  padding: 100rpx 0;
}

.prompt-icon {
  width: 180rpx;
  height: 180rpx;
  margin: 0 auto 30rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #dcfce7, #bbf7d0);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 16rpx 36rpx rgba(34, 197, 94, 0.16);
}

.prompt-icon-text {
  font-size: 34rpx;
  font-weight: 700;
  color: #166534;
  letter-spacing: 2rpx;
}

.prompt-text {
  display: block;
  font-size: 28rpx;
  color: #6b7280;
  margin-bottom: 40rpx;
}

.login-btn {
  width: 100%;
  background: linear-gradient(135deg, #4ade80 0%, #16a34a 100%);
  color: white;
  border: none;
  border-radius: 999rpx;
  padding: 30rpx;
  font-size: 32rpx;
  font-weight: bold;
}

.login-btn:active {
  opacity: 0.8;
}

<view class="container">
  <view class="user-card" wx:if="{{userInfo}}">
    <view class="user-info">
      <view class="avatar">
        <image wx:if="{{userInfo.avatar_url}}" class="avatar-image" src="{{userInfo.avatar_url}}" mode="aspectFill"></image>
        <text wx:else class="avatar-mark">{{userInfo.username ? userInfo.username.substring(0, 1) : 'C'}}</text>
      </view>
      <view class="user-details">
        <text class="username">{{userInfo.nickname || userInfo.username}}</text>
        <text class="email">{{userInfo.email || '微信快捷登录用户'}}</text>
      </view>
    </view>

    <view class="user-stats">
      <view class="stat-item">
        <text class="stat-label">总积分</text>
        <text class="stat-value text-primary">{{userInfo.total_points}}</text>
      </view>
      <view class="stat-item">
        <text class="stat-label">微信步数</text>
        <text class="stat-value text-primary">{{userInfo.step_count || 0}}</text>
      </view>
    </view>

    <view class="sync-card">
      <view class="sync-copy">
        <text class="sync-title">同步微信运动</text>
        <text class="sync-desc">最近同步：{{userInfo.step_updated_at || '未同步'}}</text>
      </view>
      <button class="sync-btn" bindtap="syncWeRunData" loading="{{syncLoading}}">同步步数</button>
    </view>
  </view>

  <view class="menu-list">
    <view class="menu-item" bindtap="goToRecords">
      <view class="menu-icon menu-records">REC</view>
      <text class="menu-text">历史记录</text>
      <view class="arrow-icon">></view>
    </view>

    <view class="menu-item" bindtap="goToStats">
      <view class="menu-icon menu-stats">DATA</view>
      <text class="menu-text">数据统计</text>
      <view class="arrow-icon">></view>
    </view>

    <view class="menu-item" bindtap="goToChangePassword">
      <view class="menu-icon menu-key">KEY</view>
      <text class="menu-text">修改密码</text>
      <view class="arrow-icon">></view>
    </view>

    <view class="menu-item" bindtap="logout">
      <view class="menu-icon menu-exit">OUT</view>
      <text class="menu-text text-danger">退出登录</text>
      <view class="arrow-icon">></view>
    </view>
  </view>

  <view class="login-prompt" wx:if="{{!userInfo}}">
    <view class="prompt-icon">
      <text class="prompt-icon-text">LOG</text>
    </view>
    <text class="prompt-text">请先登录后再查看个人数据</text>
    <button class="login-btn" bindtap="goToLogin">立即登录</button>
  </view>
</view>

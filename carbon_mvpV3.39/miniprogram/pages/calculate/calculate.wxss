.container {
  min-height: 100vh;
  background:
    radial-gradient(circle at top right, rgba(59, 130, 246, 0.12), transparent 22%),
    linear-gradient(180deg, #f4fbf5 0%, #eef8f1 52%, #f8fbf7 100%);
  padding: 40rpx 28rpx;
}

.card {
  background-color: rgba(255, 255, 255, 0.96);
  border-radius: 28rpx;
  padding: 40rpx 32rpx;
  box-shadow: 0 18rpx 36rpx rgba(15, 23, 42, 0.06);
}

.title {
  display: flex;
  align-items: center;
  margin-bottom: 40rpx;
}

.icon-badge {
  width: 92rpx;
  height: 92rpx;
  border-radius: 26rpx;
  margin-right: 22rpx;
  background: linear-gradient(135deg, #2563eb, #60a5fa);
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
  box-shadow: 0 12rpx 24rpx rgba(37, 99, 235, 0.16);
}

.title-copy {
  flex: 1;
}

.title-text {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #14532d;
  margin-bottom: 8rpx;
}

.title-subtext {
  display: block;
  font-size: 24rpx;
  color: #6b7280;
  line-height: 1.5;
}

.form {
  margin-bottom: 40rpx;
}

.input-group {
  margin-bottom: 30rpx;
}

.label {
  display: block;
  font-size: 28rpx;
  color: #374151;
  margin-bottom: 12rpx;
  font-weight: 600;
}

.input,
.picker {
  width: 100%;
  padding: 22rpx 24rpx;
  border: 2rpx solid #dbe4dd;
  border-radius: 18rpx;
  font-size: 28rpx;
  background-color: #f8faf8;
  box-sizing: border-box;
}

.calculate-btn {
  width: 100%;
  background: linear-gradient(135deg, #16a34a 0%, #22c55e 100%);
  color: white;
  border: none;
  border-radius: 999rpx;
  padding: 26rpx;
  font-size: 32rpx;
  font-weight: 700;
  margin-top: 20rpx;
}

.calculate-btn:active {
  opacity: 0.85;
}

.result {
  margin-top: 40rpx;
  padding-top: 34rpx;
  border-top: 2rpx solid #eef2ef;
}

.result-item {
  display: flex;
  justify-content: space-between;
  margin-bottom: 18rpx;
  padding: 22rpx 24rpx;
  background-color: #f9fbfa;
  border-radius: 18rpx;
}

.result-label {
  font-size: 28rpx;
  color: #6b7280;
}

.result-value {
  font-size: 32rpx;
  font-weight: 700;
  color: #374151;
}

.text-primary {
  color: #16a34a;
}

.blockchain-info {
  margin-top: 24rpx;
  padding: 24rpx;
  background-color: #eff6ff;
  border-radius: 18rpx;
  border-left: 6rpx solid #3b82f6;
}

.blockchain-label {
  display: block;
  font-size: 24rpx;
  color: #6b7280;
  margin-bottom: 10rpx;
}

.blockchain-hash {
  font-size: 20rpx;
  color: #374151;
  word-break: break-all;
  line-height: 1.6;
  font-family: monospace;
}

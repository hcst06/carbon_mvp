page {
  background-color: #f0fdf4;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', 'Helvetica Neue', Arial, sans-serif;
}

.container {
  padding: 20rpx;
}

.btn {
  background-color: #4ade80;
  color: white;
  border-radius: 40rpx;
  padding: 20rpx 40rpx;
  font-size: 32rpx;
  text-align: center;
  margin-top: 20rpx;
}

.btn:active {
  background-color: #16a34a;
}

.card {
  background-color: white;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.input-group {
  margin-bottom: 30rpx;
}

.input-group text {
  display: block;
  margin-bottom: 10rpx;
  color: #374151;
  font-size: 28rpx;
}

.input-group input {
  width: 100%;
  padding: 20rpx;
  border: 2rpx solid #e5e7eb;
  border-radius: 12rpx;
  font-size: 28rpx;
}

.input-group input:focus {
  border-color: #4ade80;
}

.text-primary {
  color: #4ade80;
}

.text-dark {
  color: #065f46;
}

.text-gray {
  color: #6b7280;
}

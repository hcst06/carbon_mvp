.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #f0fdf4 0%, #dcfce7 100%);
  padding: 40rpx;
}

.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 40rpx;
  animation: fadeIn 0.5s ease-in;
}

.user-info {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  border: 4rpx solid #4ade80;
  box-shadow: 0 4rpx 12rpx rgba(74, 222, 128, 0.3);
}

.user-details {
  flex: 1;
}

.username {
  font-size: 32rpx;
  font-weight: bold;
  color: #374151;
  margin-bottom: 5rpx;
  display: block;
}

.points {
  font-size: 24rpx;
  color: #16a34a;
  font-weight: bold;
}

.login-btn {
  font-size: 24rpx;
  color: #3b82f6;
  font-weight: bold;
  text-decoration: underline;
}

.hero-section {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #4ade80 0%, #16a34a 100%);
  border-radius: 30rpx;
  padding: 40rpx;
  margin-bottom: 40rpx;
  box-shadow: 0 8rpx 24rpx rgba(74, 222, 128, 0.3);
  animation: slideInUp 0.6s ease-out;
}

.hero-content {
  flex: 1;
  margin-right: 30rpx;
}

.hero-title {
  font-size: 48rpx;
  font-weight: bold;
  color: white;
  margin-bottom: 10rpx;
  display: block;
}

.hero-title.highlight {
  color: #fef3c7;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.2);
}

.hero-subtitle {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
  line-height: 1.4;
}

.hero-image {
  width: 200rpx;
  height: 200rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 120rpx;
  animation: bounce 2s infinite;
}

.stats-section {
  display: flex;
  justify-content: space-between;
  margin-bottom: 40rpx;
  animation: fadeIn 0.8s ease-in;
}

.stat-card {
  flex: 1;
  background-color: white;
  border-radius: 20rpx;
  padding: 30rpx;
  text-align: center;
  margin: 0 10rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  transition: transform 0.3s ease, box-shadow 0.3s ease;
}

.stat-card:hover {
  transform: translateY(-10rpx);
  box-shadow: 0 8rpx 24rpx rgba(74, 222, 128, 0.2);
}

.stat-icon {
  width: 60rpx;
  height: 60rpx;
  margin: 0 auto 20rpx;
}

.stat-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #16a34a;
  margin-bottom: 10rpx;
  display: block;
}

.stat-label {
  font-size: 20rpx;
  color: #6b7280;
}

.features-section {
  margin-bottom: 40rpx;
  animation: fadeIn 1s ease-in;
}

.section-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #374151;
  margin-bottom: 30rpx;
  text-align: center;
  position: relative;
}

.section-title::after {
  content: '';
  position: absolute;
  bottom: -10rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 100rpx;
  height: 6rpx;
  background: linear-gradient(90deg, #4ade80, #16a34a);
  border-radius: 3rpx;
}

.feature-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}

.feature-card {
  background-color: white;
  border-radius: 20rpx;
  padding: 30rpx;
  text-align: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  transition: transform 0.3s ease, box-shadow 0.3s ease;
  cursor: pointer;
}

.feature-card:hover {
  transform: translateY(-5rpx);
  box-shadow: 0 8rpx 24rpx rgba(74, 222, 128, 0.2);
}

.feature-icon {
  width: 100rpx;
  height: 100rpx;
  margin: 0 auto 20rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.feature-icon.calculate {
  background: linear-gradient(135deg, #3b82f6, #60a5fa);
}

.feature-icon.track {
  background: linear-gradient(135deg, #8b5cf6, #a78bfa);
}

.feature-icon.exchange {
  background: linear-gradient(135deg, #f59e0b, #fbbf24);
}

.feature-icon.stats {
  background: linear-gradient(135deg, #ef4444, #f87171);
}

.feature-icon image {
  width: 60rpx;
  height: 60rpx;
}

.feature-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #374151;
  margin-bottom: 10rpx;
}

.feature-desc {
  font-size: 20rpx;
  color: #6b7280;
  line-height: 1.4;
}

.news-section {
  margin-bottom: 40rpx;
  animation: fadeIn 1.2s ease-in;
}

.news-card {
  display: flex;
  background-color: white;
  border-radius: 20rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  transition: transform 0.3s ease, box-shadow 0.3s ease;
}

.news-card:hover {
  transform: translateX(10rpx);
  box-shadow: 0 8rpx 24rpx rgba(74, 222, 128, 0.2);
}

.news-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 10rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.news-content {
  flex: 1;
}

.news-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #374151;
  margin-bottom: 10rpx;
  display: block;
  line-height: 1.3;
}

.news-desc {
  font-size: 20rpx;
  color: #6b7280;
  margin-bottom: 10rpx;
  line-height: 1.4;
}

.news-date {
  font-size: 18rpx;
  color: #9ca3af;
}

.footer {
  text-align: center;
  padding: 40rpx 0;
  animation: fadeIn 1.4s ease-in;
}

.footer-text {
  font-size: 24rpx;
  color: #6b7280;
  margin-bottom: 10rpx;
  display: block;
}

.footer-subtext {
  font-size: 20rpx;
  color: #9ca3af;
}

/* 动画效果 */
@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes slideInUp {
  from {
    opacity: 0;
    transform: translateY(40rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes bounce {
  0%, 20%, 50%, 80%, 100% {
    transform: translateY(0);
  }
  40% {
    transform: translateY(-20rpx);
  }
  60% {
    transform: translateY(-10rpx);
  }
}

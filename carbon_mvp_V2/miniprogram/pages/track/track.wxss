.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #f0fdf4 0%, #dcfce7 100%);
  padding: 40rpx;
}

.header {
  text-align: center;
  margin-bottom: 40rpx;
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  color: #16a34a;
  margin-bottom: 10rpx;
}

.subtitle {
  font-size: 24rpx;
  color: #6b7280;
}

.map-container {
  width: 100%;
  height: 500rpx;
  border-radius: 20rpx;
  overflow: hidden;
  margin-bottom: 40rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.map {
  width: 100%;
  height: 100%;
}

.status-section {
  display: flex;
  justify-content: space-around;
  background-color: white;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 40rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.status-item {
  text-align: center;
}

.status-label {
  display: block;
  font-size: 24rpx;
  color: #6b7280;
  margin-bottom: 10rpx;
}

.status-value {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #16a34a;
}

.control-section {
  margin-bottom: 40rpx;
}

.control-btn {
  width: 100%;
  padding: 30rpx;
  border-radius: 20rpx;
  font-size: 32rpx;
  font-weight: bold;
  border: none;
  color: white;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.control-btn.start {
  background: linear-gradient(135deg, #4ade80 0%, #16a34a 100%);
}

.control-btn.pause {
  background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%);
  margin-right: 20rpx;
  flex: 1;
}

.control-btn.stop {
  background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%);
  flex: 1;
}

.control-buttons {
  display: flex;
  gap: 20rpx;
}

.mode-section {
  background-color: white;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 40rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.mode-label {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #374151;
  margin-bottom: 20rpx;
}

.mode-picker {
  width: 100%;
}

.picker {
  width: 100%;
  padding: 20rpx;
  border: 2rpx solid #e5e7eb;
  border-radius: 10rpx;
  font-size: 28rpx;
  background-color: #f9fafb;
}

.tips {
  background-color: #f0f9ff;
  border-left: 4rpx solid #3b82f6;
  padding: 20rpx;
  border-radius: 10rpx;
  font-size: 24rpx;
  color: #374151;
  line-height: 1.4;
}

.container {
  padding: 30rpx;
}

.user-card {
  background: linear-gradient(135deg, #4ade80 0%, #16a34a 100%);
  border-radius: 20rpx;
  padding: 40rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(74, 222, 128, 0.3);
}

.user-info {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  background-color: white;
  margin-right: 30rpx;
}

.user-details {
  flex: 1;
}

.username {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: white;
  margin-bottom: 10rpx;
}

.email {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
}

.user-stats {
  display: flex;
  justify-content: center;
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.3);
}

.stat-item {
  text-align: center;
}

.stat-label {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-bottom: 10rpx;
}

.stat-value {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: white;
}

.text-primary {
  color: white;
}

.menu-list {
  background-color: white;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f3f4f6;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  width: 50rpx;
  height: 50rpx;
  margin-right: 20rpx;
}

.menu-text {
  flex: 1;
  font-size: 28rpx;
  color: #374151;
}

.arrow-icon {
  width: 30rpx;
  height: 30rpx;
}

.text-danger {
  color: #ef4444;
}

.login-prompt {
  text-align: center;
  padding: 100rpx 0;
}

.prompt-icon {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 30rpx;
}

.prompt-text {
  display: block;
  font-size: 28rpx;
  color: #6b7280;
  margin-bottom: 40rpx;
}

.login-btn {
  width: 100%;
  background: linear-gradient(135deg, #4ade80 0%, #16a34a 100%);
  color: white;
  border: none;
  border-radius: 50rpx;
  padding: 30rpx;
  font-size: 32rpx;
  font-weight: bold;
}

.login-btn:active {
  opacity: 0.8;
}

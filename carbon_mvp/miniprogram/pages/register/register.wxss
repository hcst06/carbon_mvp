.register-container {
  min-height: 100vh;
  background: linear-gradient(135deg, #4ade80 0%, #16a34a 100%);
  padding: 60rpx 40rpx;
}

.logo-section {
  text-align: center;
  margin-bottom: 60rpx;
}

.logo {
  width: 200rpx;
  height: 200rpx;
  border-radius: 100rpx;
  background-color: white;
  padding: 20rpx;
  margin-bottom: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 100rpx;
}

.app-name {
  display: block;
  color: white;
  font-size: 48rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.app-slogan {
  display: block;
  color: rgba(255, 255, 255, 0.9);
  font-size: 28rpx;
}

.form-section {
  background-color: white;
  border-radius: 30rpx;
  padding: 50rpx 40rpx;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.2);
}

.input-group {
  position: relative;
  margin-bottom: 30rpx;
}

.input-icon {
  position: absolute;
  left: 30rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}

.input-field {
  width: 100%;
  padding: 25rpx 30rpx 25rpx 90rpx;
  border: 2rpx solid #e5e7eb;
  border-radius: 50rpx;
  font-size: 28rpx;
  background-color: #f9fafb;
}

.input-field:focus {
  border-color: #4ade80;
  background-color: white;
}

.register-btn {
  width: 100%;
  background: linear-gradient(135deg, #4ade80 0%, #16a34a 100%);
  color: white;
  border: none;
  border-radius: 50rpx;
  padding: 30rpx;
  font-size: 32rpx;
  font-weight: bold;
  margin-top: 30rpx;
}

.register-btn:active {
  opacity: 0.8;
}

.divider {
  display: flex;
  align-items: center;
  margin: 40rpx 0;
}

.divider::before,
.divider::after {
  content: '';
  flex: 1;
  height: 1rpx;
  background-color: #e5e7eb;
}

.divider text {
  margin: 0 20rpx;
  color: #6b7280;
  font-size: 24rpx;
}

.wechat-login-btn {
  width: 100%;
  background-color: #07C160;
  color: white;
  border: none;
  border-radius: 50rpx;
  padding: 30rpx;
  font-size: 32rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
}

.wechat-login-btn:active {
  opacity: 0.8;
}

.wechat-icon {
  width: 40rpx;
  height: 40rpx;
  margin-right: 15rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}

.login-link {
  text-align: center;
  margin-top: 40rpx;
  font-size: 28rpx;
  color: #6b7280;
}

.link-text {
  color: #4ade80;
  font-weight: bold;
  margin-left: 10rpx;
}
